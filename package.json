{
  "name": "root",
  "private": true,
  "repository": "https://gitlab.kilic.dev/libraries/oclif-common",
  "type": "module",
  "scripts": {
    "clean": "rimraf node_modules pnpm-lock.yaml",
    "build": "pnpm run -r build",
    "format": "pnpm run --parallel -r format",
    "lint": "pnpm run --parallel -r lint"
  },
  "workspaces": [
    "packages/*",
    "example"
  ],
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "prepare-commit-msg": "[ -t 1 ] && exec < /dev/tty && git cz --hook || true"
  },
  "devDependencies": {
    "@cenk1cenk2/cz-cc": "^2.2.22",
    "@cenk1cenk2/eslint-config": "^3.2.6",
    "@tsconfig/node24": "^24.0.4",
    "commitizen": "^4.3.2",
    "eslint": "^10.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.6",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@cenk1cenk2/cz-cc"
    }
  }
}
