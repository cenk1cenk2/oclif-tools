{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "src",
    "paths": {
      "@commands": ["./src/commands/index.ts"],
      "@constants": ["./src/constants/index.ts"],
      "@interfaces": ["./src/interfaces/index.ts"],
      "@lib": ["./src/lib/index.ts"],
      "@lib/*": ["./src/lib/*"],
      "@utils": ["./src/utils/index.ts"]
    },
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
